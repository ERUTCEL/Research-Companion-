# Required
ANTHROPIC_API_KEY=sk-ant-...

# Optional — only needed for Notion ingestion
NOTION_TOKEN=secret_...

# Optional — override defaults
CHROMA_PERSIST_DIR=./chroma_db
SQLITE_DB_PATH=./metadata.db
EMBEDDER_MODEL=BAAI/bge-m3
LITE_MODE=false          # set true on low-spec machines (CPU-only, no GPU parsers)
LOG_LEVEL=INFO

# Optional local LLM reasoner for figure/diagram structuring.
# Recommended target users: Qwen3 14B Q4 on 16GB+ RAM, Qwen3 7B fallback on lighter laptops.
LOCAL_REASONER_ENABLED=true
OLLAMA_BASE_URL=http://127.0.0.1:11434
LOCAL_REASONER_MODEL=qwen3:14b
LOCAL_REASONER_FALLBACK_MODEL=qwen3:7b
LOCAL_REASONER_DEEP_MODEL=deepseek-r1:14b
LOCAL_REASONER_TIMEOUT_S=12
